# Supabase — @nuxtjs/supabase (v2)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<publishable-anon-key>
SUPABASE_SECRET_KEY=<service-role-secret-key>   # SERVER ONLY
SUPABASE_ANON_KEY=<jwt-anon-key>                # untuk test/Auth admin
SUPABASE_PROJECT_REF=<project-ref>

# Koneksi Postgres langsung untuk migrasi DDL.
# Dashboard → Project Settings → Database → Connection string (pooler, session mode).
SUPABASE_DB_URL=postgresql://postgres.<ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
